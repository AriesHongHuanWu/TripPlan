rules_version = '2';

// ============================================================================
// Plan AI — Firestore security rules
// ----------------------------------------------------------------------------
// Enforces the Google-Docs-style sharing model SERVER-SIDE so permissions are
// real (not just hidden in the UI). Publish via:
//   • Firebase console → Firestore Database → Rules → paste → Publish, OR
//   • firebase deploy --only firestore:rules   (needs firebase.json + .firebaserc)
//
// Access model on a collab/{code} document:
//   owner: <uid>
//   access: {
//     general: 'restricted' | 'viewer' | 'commenter' | 'editor',  // role for anyone with the link
//     people:  { <emailKey>: { role:'editor'|'commenter'|'viewer', name, ts } }
//   }
// Role precedence: owner > listed person > general (unless 'restricted').
// emailKey is the lower-cased Google email (matched against request.auth.token.email).
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myEmail()  { return signedIn() ? request.auth.token.email : null; }

    // ---- per-user private cloud mirror ----
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // ---- legacy "copy share" snapshots (anyone with the code loads their OWN copy) ----
    match /shared/{code} {
      allow read:  if true;          // snapshots are intentionally public-by-code
      allow write: if signedIn();    // low risk: it's a detached copy, never the live doc
    }

    // ---- live, permissioned collaborative plans ----
    match /collab/{code} {
      function hasAccess()   { return 'access' in resource.data && resource.data.access != null; }
      function gen()         { return hasAccess() && 'general' in resource.data.access ? resource.data.access.general : 'editor'; }
      function ppl()         { return hasAccess() && 'people'  in resource.data.access ? resource.data.access.people  : {}; }
      function listed()      { return myEmail() != null && myEmail() in ppl(); }
      function personRole()  { return ppl()[myEmail()].role; }
      function isOwner()     { return signedIn() && resource.data.owner == request.auth.uid; }
      function canRead()     { return isOwner() || listed() || gen() != 'restricted'; }
      function canEdit()     { return isOwner() || (listed() && personRole() == 'editor') || (!listed() && gen() == 'editor'); }
      // A read-capable member may update only their own presence (members/ts).
      function onlyPresenceChanged() { return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'ts']); }
      // Editors may change the itinerary but never the access map or owner.
      // .get(key, default) tolerates legacy docs that predate the `access` field.
      function accessUnchanged() {
        return request.resource.data.get('access', {}) == resource.data.get('access', {})
            && request.resource.data.get('owner', '')  == resource.data.get('owner', '')
            && request.resource.data.get('visibility', '') == resource.data.get('visibility', '');   // owner-only field
      }

      allow get, list: if canRead();
      allow create:    if signedIn() && request.resource.data.owner == request.auth.uid;
      allow update:    if isOwner()
                       || (canEdit() && accessUnchanged())
                       || (canRead() && onlyPresenceChanged());
      allow delete:    if isOwner();

      // ---- group chat / comments ----
      match /messages/{msg} {
        function parent()    { return get(/databases/$(database)/documents/collab/$(code)).data; }
        function pAccess()   { return 'access' in parent() ? parent().access : {}; }
        function pGen()      { return 'general' in pAccess() ? pAccess().general : 'editor'; }
        function pPpl()      { return 'people'  in pAccess() ? pAccess().people  : {}; }
        function pListed()   { return myEmail() != null && myEmail() in pPpl(); }
        function pOwner()    { return signedIn() && parent().owner == request.auth.uid; }
        function pCanRead()  { return pOwner() || pListed() || pGen() != 'restricted'; }
        function pCanComment() {
          return pOwner()
              || (pListed() && pPpl()[myEmail()].role in ['editor', 'commenter'])
              || (!pListed() && pGen() in ['editor', 'commenter']);
        }
        allow read:          if pCanRead();
        allow create:        if pCanComment();
        allow update, delete: if false;   // messages are immutable
      }
    }

    // ---- community feed: public mirror (safe metadata only; the model lives in collab/) ----
    match /feed/{code} {
      // Only the owner of the matching collab/{code} may write metadata (verified via get()).
      function collabOwner() { return get(/databases/$(database)/documents/collab/$(code)).data.owner; }
      function isFeedOwner() { return signedIn() && request.auth.uid == collabOwner(); }
      function likeCountSane() { return request.resource.data.get('likeCount', 0) is int && request.resource.data.get('likeCount', 0) >= 0; }
      function likeDelta() { return request.resource.data.get('likeCount', 0) - resource.data.get('likeCount', 0); }
      // A like/unlike must move likeCount in LOCK-STEP with the caller's own like marker, written in
      // the SAME transaction (feedLikeToggle). existsAfter() sees the marker's post-commit state, so
      // the counter cannot be inflated/deflated without a matching one-per-uid like doc transition.
      function genuineLike() {
        return likeDelta() == 1
            && !exists(/databases/$(database)/documents/feed/$(code)/likes/$(request.auth.uid))
            && existsAfter(/databases/$(database)/documents/feed/$(code)/likes/$(request.auth.uid));
      }
      function genuineUnlike() {
        return likeDelta() == -1
            && exists(/databases/$(database)/documents/feed/$(code)/likes/$(request.auth.uid))
            && !existsAfter(/databases/$(database)/documents/feed/$(code)/likes/$(request.auth.uid));
      }
      function likeUpdate() {
        return signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'updatedAt'])
            && likeCountSane()                              // never negative
            && (genuineLike() || genuineUnlike());
      }
      // Review counters move IN LOCK-STEP with the caller's own review doc (same transaction).
      function myReview() { return /databases/$(database)/documents/feed/$(code)/reviews/$(request.auth.uid); }
      function reviewCountDelta() { return request.resource.data.get('reviewCount', 0) - resource.data.get('reviewCount', 0); }
      function ratingSumDelta() { return request.resource.data.get('ratingSum', 0) - resource.data.get('ratingSum', 0); }
      function reviewAdd()  { return reviewCountDelta() == 1  && !exists(myReview()) && existsAfter(myReview()) && ratingSumDelta() == getAfter(myReview()).data.rating; }
      function reviewEdit() { return reviewCountDelta() == 0  && exists(myReview()) && existsAfter(myReview()) && ratingSumDelta() == getAfter(myReview()).data.rating - get(myReview()).data.rating; }
      function reviewDel()  { return reviewCountDelta() == -1 && exists(myReview()) && !existsAfter(myReview()) && ratingSumDelta() == 0 - get(myReview()).data.rating; }
      function reviewUpdate() {
        return signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewCount', 'ratingSum', 'updatedAt'])
            && request.resource.data.get('reviewCount', 0) >= 0
            && (reviewAdd() || reviewEdit() || reviewDel());
      }
      // Any signed-in user may bump forkCount by exactly +1 (copying a plan; low-stakes, no marker).
      function forkBump() {
        return signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['forkCount', 'updatedAt'])
            && (request.resource.data.get('forkCount', 0) - resource.data.get('forkCount', 0)) == 1;
      }

      allow get, list: if true;                                  // public discovery + fork
      allow create:    if isFeedOwner() && likeCountSane();
      // Cheap public branches FIRST so a like/review/fork never needs get(collab).
      allow update:    if likeUpdate() || reviewUpdate() || forkBump() || (isFeedOwner() && likeCountSane());
      // Self-authorizing via the feed doc's own owner field, so delisting still works after collab is gone.
      allow delete:    if signedIn() && request.auth.uid == resource.data.get('owner', '');

      // one-per-user like marker (doc id == uid ⇒ uniqueness for free)
      match /likes/{uid} {
        allow get, list:     if true;                            // counts/state are public
        allow create, delete: if signedIn() && request.auth.uid == uid;
        allow update:        if false;                           // likes are immutable
      }

      // one review per user (doc id == uid); rating 1-5, text <=600. Edit-in-place.
      match /reviews/{uid} {
        function feedOwner() { return get(/databases/$(database)/documents/feed/$(code)).data.get('owner', ''); }
        function validReview() {
          return request.resource.data.rating is int
              && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
              && request.resource.data.text.size() <= 600;
        }
        // A voter (≠ the review author) may move ONLY the `helpful` counter by ±1, in lock-step
        // with their own one-per-voter helpful doc (same transaction).
        function myVote() { return /databases/$(database)/documents/feed/$(code)/reviews/$(uid)/helpful/$(request.auth.uid); }
        function helpfulDelta() { return request.resource.data.get('helpful', 0) - resource.data.get('helpful', 0); }
        function helpfulUpdate() {
          return signedIn()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpful'])
              && ( (helpfulDelta() == 1  && !exists(myVote()) && existsAfter(myVote()))
                || (helpfulDelta() == -1 &&  exists(myVote()) && !existsAfter(myVote())) );
        }
        allow get, list: if true;
        allow create:    if signedIn() && request.auth.uid == uid && validReview();
        allow update:    if (signedIn() && request.auth.uid == uid && validReview()) || helpfulUpdate();
        allow delete:    if signedIn() && (request.auth.uid == uid || request.auth.uid == feedOwner());  // self or plan owner (moderation)

        // helpful votes — one per voter
        match /helpful/{voter} {
          allow get, list:      if true;
          allow create, delete: if signedIn() && request.auth.uid == voter;
          allow update:         if false;
        }
      }
    }
  }
}
